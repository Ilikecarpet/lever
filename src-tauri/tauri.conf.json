{
  "productName": "Lever",
  "version": "1.0.0",
  "identifier": "com.lever.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd ../ui && npm run dev",
    "beforeBuildCommand": "cd ../ui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lever",
        "width": 900,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "titleBarStyle": "Visible",
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
