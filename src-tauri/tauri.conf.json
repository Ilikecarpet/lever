{
  "productName": "Lever",
  "version": "1.0.0",
  "identifier": "com.lever.dev",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev --prefix ../ui",
    "beforeBuildCommand": "npm run build --prefix ../ui"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lever — Start",
        "width": 700,
        "height": 500,
        "minWidth": 500,
        "minHeight": 350,
        "titleBarStyle": "Visible",
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
